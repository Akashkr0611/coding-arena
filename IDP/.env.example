# ─── CoastWise India — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values before running the app.
#
# USAGE:
#   cp .env.example .env
#   npm run build
#   npm start
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
# Required for the chatbot. Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=

# ─── Weather API ──────────────────────────────────────────────────────────────
# Optional. Get yours at: https://openweathermap.org/api
# If not set, the app uses smart mock data instead.
OPENWEATHER_API_KEY=

# ─── Database (optional — SQLite is used by default) ─────────────────────────
# Only required when connecting to PostgreSQL (e.g. Supabase, AWS RDS).
# Leave blank to use the local SQLite database file (database.sqlite).
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=coastwise

# ─── Frontend URL (optional) ──────────────────────────────────────────────────
# Set this if your frontend is hosted on a separate domain.
FRONTEND_URL=
